{
  "openapi": "3.0.1",
  "info": {
    "title": "OneDrive Assistant API",
    "description": "Secure, cost-efficient OneDrive document search and AI-powered summarization/chat.",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "https://onedrive-agent-api.onrender.com"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "tags": ["Search"],
        "operationId": "searchDocuments",
        "summary": "Search OneDrive (metadata only — zero AI cost)",
        "description": "Performs a lightning-fast keyword search across the user's OneDrive. Returns metadata only. No AI is used for this operation.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search keywords (e.g. 'budget', 'roadmap')",
            "schema": { "type": "string", "minLength": 2, "maxLength": 256, "example": "Q4 budget report" }
          },
          {
            "name": "top",
            "in": "query",
            "required": false,
            "description": "Max results (1-50)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 25 }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results returned",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchResponse" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/document/{item_id}": {
      "get": {
        "tags": ["Document"],
        "operationId": "getDocumentDetail",
        "summary": "Get file metadata (zero AI cost)",
        "description": "Fetches technical metadata and a temporary download link for a specific OneDrive item.",
        "parameters": [
          {
            "name": "item_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Metadata returned",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DocumentDetail" } } }
          }
        }
      }
    },
    "/summarize": {
      "post": {
        "tags": ["AI"],
        "operationId": "summarizeDocument",
        "summary": "Summarize a document (AI — on-demand only)",
        "description": "Downloads the document and generates a 3-5 sentence summary. AI is only called when this endpoint is hit.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SummarizeRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Summary returned",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SummaryResponse" } } }
          },
          "413": { "description": "Document too large (>1.5MB)" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/chat": {
      "post": {
        "tags": ["AI"],
        "operationId": "chatWithDocument",
        "summary": "Ask a specific question about a document (AI Q&A)",
        "description": "Downloads the document and uses AI to answer a specific question based ONLY on the content found in that file.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChatRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Answer returned",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChatResponse" } } }
          },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "operationId": "healthCheck",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "version", "ai_provider"],
        "properties": {
          "status": { "type": "string" },
          "version": { "type": "string" },
          "ai_provider": { "type": "string", "enum": ["openai", "azure_openai", "google_ai_studio", "groq"] }
        }
      },
      "SearchResultItem": {
        "type": "object",
        "required": ["id", "name", "webUrl"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "webUrl": { "type": "string" },
          "lastModifiedDateTime": { "type": "string", "nullable": true },
          "fileType": { "type": "string", "nullable": true }
        }
      },
      "SearchResponse": {
        "type": "object",
        "required": ["query", "total", "results"],
        "properties": {
          "query": { "type": "string" },
          "total": { "type": "integer" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/SearchResultItem" } }
        }
      },
      "DocumentDetail": {
        "type": "object",
        "required": ["id", "name", "webUrl"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "webUrl": { "type": "string" },
          "size": { "type": "integer", "nullable": true }
        }
      },
      "SummarizeRequest": {
        "type": "object",
        "required": ["documentId"],
        "properties": {
          "documentId": { "type": "string" },
          "maxTokens": { "type": "integer", "default": 500 }
        }
      },
      "SummaryResponse": {
        "type": "object",
        "required": ["documentId", "documentName", "summary", "keyPoints", "cached"],
        "properties": {
          "documentId": { "type": "string" },
          "documentName": { "type": "string" },
          "summary": { "type": "string" },
          "keyPoints": { "type": "array", "items": { "type": "string" } },
          "cached": { "type": "boolean" },
          "modelUsed": { "type": "string", "nullable": true }
        }
      },
      "ChatRequest": {
        "type": "object",
        "required": ["documentId", "question"],
        "properties": {
          "documentId": { "type": "string" },
          "question": { "type": "string" }
        }
      },
      "ChatResponse": {
        "type": "object",
        "required": ["answer", "documentName"],
        "properties": {
          "answer": { "type": "string" },
          "documentName": { "type": "string" },
          "modelUsed": { "type": "string", "nullable": true }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "responses": {
      "Unauthorized": { "description": "Unauthorized" },
      "Forbidden": { "description": "Forbidden" },
      "NotFound": { "description": "Not Found" },
      "BadGateway": { "description": "AI or Graph Error" },
      "GatewayTimeout": { "description": "Timeout" }
    }
  }
}
