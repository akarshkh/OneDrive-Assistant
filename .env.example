# ─────────────────────────────────────────────────────────────────────────────
# OneDrive Agent API — Environment Variables
# Copy this file to `.env` and fill in your values.
# NEVER commit the populated .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure / Entra ID (REQUIRED) ───────────────────────────────────────────────
# Your Azure AD Tenant ID (GUID from Azure Portal → Azure Active Directory → Overview)
AZURE_TENANT_ID=your-tenant-id-here

# The App Registration's Application (client) ID
# This is also the expected audience in JWT tokens: api://<AZURE_CLIENT_ID>
AZURE_CLIENT_ID=your-client-id-here

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose: "openai" or "azure_openai"
AI_PROVIDER=openai

# ── OpenAI (if AI_PROVIDER=openai) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Recommended: gpt-4o-mini (cheapest capable model)
OPENAI_MODEL=gpt-4o-mini

# ── Azure OpenAI (if AI_PROVIDER=azure_openai) ───────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Cost / Limits ─────────────────────────────────────────────────────────────
# Max document size accepted for summarization (bytes). Default: 1.5 MB
MAX_CONTENT_BYTES=1572864

# Max characters sent to AI per request (~3000 tokens). Lower = cheaper.
SUMMARIZE_MAX_CHARS=12000

# How long (seconds) to cache a summary before allowing re-summarization
SUMMARY_CACHE_TTL=3600

# Max number of summaries to hold in memory simultaneously
SUMMARY_CACHE_MAX_SIZE=500

# ── Graph API ─────────────────────────────────────────────────────────────────
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_TIMEOUT_SECONDS=30

# ── Server ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Use * only in development.
ALLOWED_ORIGINS=["*"]

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
